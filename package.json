{
    "name": "task-processing-pipeline",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "start": "bun src/index.ts",
        "dev": "bun --watch src/index.ts",
        "format:write": "prettier --write \"src/**/*.{js,ts,json,css,md}\"",
        "format:check": "prettier --check \"src/**/*.{js,ts,json,css,md}\"",
        "lint": "eslint .",
        "workers": "bun src/workers/run.ts",
        "workers:processor": "bun src/workers/run.ts processor",
        "workers:delivery": "bun src/workers/run.ts delivery",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate"
    },
    "dependencies": {
        "drizzle-orm": "^0.45.1",
        "drizzle-zod": "^0.8.3",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.1",
        "postgres": "^3.4.8",
        "rate-limit-redis": "^4.3.1",
        "redis": "^5.11.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bun": "^1.3.10",
        "@types/express": "^5.0.6",
        "drizzle-kit": "^0.31.9",
        "eslint": "^10.0.3",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "typescript-eslint": "^8.57.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}
