{
    "name": "task-processing-pipeline",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "start": "bun src/index.ts",
        "dev": "bun --watch src/index.ts",
        "format:write": "prettier --write \"src/**/*.{js,ts,json,css,md}\"",
        "format:check": "prettier --check \"src/**/*.{js,ts,json,css,md}\"",
        "lint": "eslint .",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate"
    },
    "dependencies": {
        "drizzle-orm": "^0.45.1",
        "eslint": "^10.0.2",
        "express": "^5.2.1",
        "postgres": "^3.4.8"
    },
    "devDependencies": {
        "@types/bun": "^1.3.10",
        "@types/express": "^5.0.6",
        "drizzle-kit": "^0.31.9",
        "prettier": "^3.8.1"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}
